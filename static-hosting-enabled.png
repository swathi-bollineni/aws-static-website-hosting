="1887" height="1079" loading="lazy" decoding="async" class="max-w-full object-cover object-center overflow-hidden rounded-lg w-full h-full max-w-96 max-h-64 w-fit transition-opacity duration-300 opacity-100" src="./static-hosting-enabled_files/823c1002-bace-4f86-972a-73a89c7ae2d1.png"></button></div></div></div></div></div></div><div class="text-token-text-secondary my-2 me-4 flex flex-row justify-end gap-1 text-xs"></div></div><div class="z-0 flex justify-end"><div class="touch:-me-2 touch:-ms-3.5 -ms-2.5 -me-1 flex flex-wrap items-center gap-y-4 p-1 select-none focus-within:transition-none hover:transition-none touch:pointer-events-auto touch:opacity-100 duration-300 group-hover/turn-messages:delay-300 pointer-events-none opacity-0 motion-safe:transition-opacity group-hover/turn-messages:pointer-events-auto group-hover/turn-messages:opacity-100 group-focus-within/turn-messages:pointer-events-auto group-focus-within/turn-messages:opacity-100 has-data-[state=open]:pointer-events-auto has-data-[state=open]:opacity-100" style="mask-position: 0% 0%;"><button class="text-token-text-secondary hover:bg-token-bg-secondary rounded-lg" aria-label="Copy message" data-testid="copy-turn-action-button" data-state="closed"><span class="flex items-center justify-center touch:w-10 h-8 w-8"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-il7yfj1b.svg#ce3544" fill="currentColor"></use></svg></span></button><button class="text-token-text-secondary hover:bg-token-bg-secondary rounded-lg" aria-label="Edit message" data-state="closed"><span class="flex items-center justify-center touch:w-10 h-8 w-8"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-il7yfj1b.svg#6d87e1" fill="currentColor"></use></svg></span></button></div></div></div></div><span class="sr-only"><br></span></article><article class="text-token-text-primary w-full focus:outline-none [--shadow-height:45px] has-data-writing-block:pointer-events-none has-data-writing-block:-mt-(--shadow-height) has-data-writing-block:pt-(--shadow-height) [&amp;:has([data-writing-block])&gt;*]:pointer-events-auto scroll-mt-[calc(var(--header-height)+min(200px,max(70px,20svh)))]" tabindex="-1" dir="auto" data-turn-id="request-WEB:c1480023-29e0-4946-9cd7-fe18d94e49f3-14" data-testid="conversation-turn-30" data-scroll-anchor="false" data-turn="assistant" style=""><h6 class="sr-only select-none">ChatGPT said:</h6><div class="text-base my-auto mx-auto [--thread-content-margin:var(--thread-content-margin-xs,calc(var(--spacing)*4))] @w-sm/main:[--thread-content-margin:var(--thread-content-margin-sm,calc(var(--spacing)*6))] @w-lg/main:[--thread-content-margin:var(--thread-content-margin-lg,calc(var(--spacing)*16))] px-(--thread-content-margin)"><div tabindex="-1" class="[--thread-content-max-width:40rem] @w-lg/main:[--thread-content-max-width:48rem] mx-auto max-w-(--thread-content-max-width) flex-1 group/turn-messages focus-visible:outline-hidden relative flex w-full min-w-0 flex-col agent-turn"><div class="flex max-w-full flex-col gap-4 grow"><div data-message-author-role="assistant" data-message-id="505bebd1-b03f-41dc-9119-c08382fc6b60" dir="auto" data-message-model-slug="gpt-5-3" class="min-h-8 text-message relative flex w-full flex-col items-end gap-2 text-start break-words whitespace-normal [.text-message+&amp;]:mt-1"><div class="flex w-full flex-col gap-1 empty:hidden"><div class="markdown prose dark:prose-invert w-full wrap-break-word light markdown-new-styling"><p data-start="0" data-end="132">Excellent! 🎉<br data-start="13" data-end="16">
Your website is <strong data-start="32" data-end="66">working successfully on AWS S3</strong>. I can see the page <strong data-start="87" data-end="118">“Welcome to My Travel Blog”</strong>, which means:</p>
<p data-start="134" data-end="271">✅ S3 bucket created<br data-start="153" data-end="156">
✅ index.html uploaded<br data-start="177" data-end="180">
✅ Static website hosting enabled<br data-start="212" data-end="215">
✅ Bucket made public<br data-start="235" data-end="238">
✅ Website accessible in browser</p>
<p data-start="273" data-end="403">This already satisfies <strong data-start="296" data-end="331">most of the rubric requirements</strong>. Now we only need <strong data-start="350" data-end="377">CloudFront distribution</strong>, which is the final step.</p>
<hr data-start="405" data-end="408">
<h1 data-section-id="1593iuz" data-start="410" data-end="435">Step 1: Open CloudFront</h1>
<p data-start="437" data-end="483">Go back to the AWS Console top <strong data-start="468" data-end="482">search bar</strong>.</p>
<p data-start="485" data-end="490">Type:</p>
<pre class="overflow-visible! px-0!" data-start="492" data-end="510"><div class="relative w-full mt-4 mb-1"><div class=""><div class="relative"><div class="h-full min-h-0 min-w-0"><div class="h-full min-h-0 min-w-0" style="width: 100%; transform: none;"><div class="border border-token-border-light border-radius-3xl corner-superellipse/1.1 rounded-3xl"><div class="h-full w-full border-radius-3xl bg-token-bg-elevated-secondary corner-superellipse/1.1 overflow-clip rounded-3xl lxnfua_clipPathFallback"><div class="pointer-events-none absolute end-1.5 top-1 z-2 md:end-2 md:top-1"><button class="flex gap-1 items-center select-none pointer-events-auto py-2 text-sm font-medium hover:bg-black/5 dark:hover:bg-white/10 size-9 rounded-full px-2" aria-label="Copy" data-state="closed"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-md"><use href="/cdn/assets/sprites-core-il7yfj1b.svg#ce3544" fill="currentColor"></use></svg></button></div><div class="pe-11 pt-3" style="transform: none;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼ5 ͼj"><div class="cm-scroller"><div class="cm-content q9tKkq_readonly"><span>CloudFront</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
<p data-start="512" data-end="518">Click:</p>
<p data-start="520" data-end="534"><strong data-start="520" data-end="534">CloudFront</strong></p>
<hr data-start="536" data-end="539">
<h1 data-section-id="176b5ya" data-start="541" data-end="570">Step 2: Create Distribution</h1>
<p data-start="572" data-end="596">Click the orange button:</p>
<p data-start="598" data-end="621"><strong data-start="598" data-end="621">Create distribution</strong></p>
<hr data-start="623" data-end="626">
<h1 data-section-id="1y1ylzg" data-start="628" data-end="653">Step 3: Origin Settings</h1>
<p data-start="655" data-end="709">In <strong data-start="658" data-end="675">Origin domain</strong>, select your S3 website endpoint.</p>
<p data-start="711" data-end="729">It will look like:</p>
<pre class="overflow-visible! px-0!" data-start="731" data-end="800"><div class="relative w-full mt-4 mb-1"><div class=""><div class="relative"><div class="h-full min-h-0 min-w-0"><div class="h-full min-h-0 min-w-0" style="width: 100%; transform: none;"><div class="border border-token-border-light border-radius-3xl corner-superellipse/1.1 rounded-3xl"><div class="h-full w-full border-radius-3xl bg-token-bg-elevated-secondary corner-superellipse/1.1 overflow-clip rounded-3xl lxnfua_clipPathFallback"><div class="pointer-events-none absolute end-1.5 top-1 z-2 md:end-2 md:top-1"><button class="flex gap-1 items-center select-none pointer-events-auto py-2 text-sm font-medium hover:bg-black/5 dark:hover:bg-white/10 size-9 rounded-full px-2" aria-label="Copy" data-state="closed"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-md"><use href="/cdn/assets/sprites-core-il7yfj1b.svg#ce3544" fill="currentColor"></use></svg></button></div><div class="pe-11 pt-3" style="transform: none;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼ5 ͼj"><div class="cm-scroller"><div class="cm-content q9tKkq_readonly"><span>swathi-static-website-2026.s3-website-us-east-1.amazonaws.com</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
<p data-start="802" data-end="876">Important:<br data-start="812" data-end="815">
Choose the <strong data-start="826" data-end="849">S3 website endpoint</strong>, not the normal S3 bucket.</p>
<hr data-start="878" data-end="881">
<h1 data-section-id="vswgno" data-start="883" data-end="909">Step 4: Default Settings</h1>
<p data-start="911" data-end="939">Leave everything as default:</p>
<ul data-start="941" data-end="1037">
<li data-section-id="ypk9im" data-start="941" data-end="982">
<p data-start="943" data-end="982">Viewer protocol policy → HTTP and HTTPS</p>
</li>
<li data-section-id="ju5zj1" data-start="983" data-end="1007">
<p data-start="985" data-end="1007">Cache policy → Default</p>
</li>
<li data-section-id="90z8f0" data-start="1008" data-end="1037">
<p data-start="1010" data-end="1037">Allowed methods → GET, HEAD</p>
</li>
</ul>
<p data-start="1039" data-end="1051">Scroll down.</p>
<p data-start="1053" data-end="1059">Click:</p>
<p data-start="1061" data-end="1084"><strong data-start="1061" data-end="1084">Create distribution</strong></p>
<hr data-start="1086" data-end="1089">
<h1 data-section-id="wgregi" data-start="1091" data-end="1120">Step 5: Wait for Deployment</h1>
<p data-start="1122" data-end="1142">CloudFront will say:</p>
<pre class="overflow-visible! px-0!" data-start="1144" data-end="1169"><div class="relative w-full mt-4 mb-1"><div class=""><div class="relative"><div class="h-full min-h-0 min-w-0"><div class="h-full min-h-0 min-w-0" style="width: 100%; transform: none;"><div class="border border-token-border-light border-radius-3xl corner-superellipse/1.1 rounded-3xl"><div class="h-full w-full border-radius-3xl bg-token-bg-elevated-secondary corner-superellipse/1.1 overflow-clip rounded-3xl lxnfua_clipPathFallback"><div class="pointer-events-none absolute end-1.5 top-1 z-2 md:end-2 md:top-1"><button class="flex gap-1 items-center select-none pointer-events-auto py-2 text-sm font-medium hover:bg-black/5 dark:hover:bg-white/10 size-9 rounded-full px-2" aria-label="Copy" data-state="closed"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-md"><use href="/cdn/assets/sprites-core-il7yfj1b.svg#ce3544" fill="currentColor"></use></svg></button></div><div class="pe-11 pt-3" style="transform: none;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼ5 ͼj"><div class="cm-scroller"><div class="cm-content q9tKkq_readonly"><span>Status: Deploying</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
<p data-start="1171" data-end="1210">Wait <strong data-start="1176" data-end="1192">5–10 minutes</strong> until it becomes:</p>
<pre class="overflow-visible! px-0!" data-start="1212" data-end="1228"><div class="relative w-full mt-4 mb-1"><div class=""><div class="relative"><div class="h-full min-h-0 min-w-0"><div class="h-full min-h-0 min-w-0" style="width: 100%; transform: none;"><div class="border border-token-border-light border-radius-3xl corner-superellipse/1.1 rounded-3xl"><div class="h-full w-full border-radius-3xl bg-token-bg-elevated-secondary corner-superellipse/1.1 overflow-clip rounded-3xl lxnfua_clipPathFallback"><div class="pointer-events-none absolute end-1.5 top-1 z-2 md:end-2 md:top-1"><button class="flex gap-1 items-center select-none pointer-events-auto py-2 text-sm font-medium hover:bg-black/5 dark:hover:bg-white/10 size-9 rounded-full px-2" aria-label="Copy" data-state="closed"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-md"><use href="/cdn/assets/sprites-core-il7yfj1b.svg#ce3544" fill="currentColor"></use></svg></button></div><div class="pe-11 pt-3" style="transform: none;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼ5 ͼj"><div class="cm-scroller"><div class="cm-content q9tKkq_readonly"><span>Deployed</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
<hr data-start="1230" data-end="1233">
<h1 data-section-id="cm6ak7" data-start="1235" data-end="1264">Step 6: Open CloudFront URL</h1>
<p data-start="1266" data-end="1302">You will see a <strong data-start="1281" data-end="1296">Domain Name</strong> like:</p>
<pre class="overflow-visible! px-0!" data-start="1304" data-end="1338"><div class="relative w-full mt-4 mb-1"><div class=""><div class="relative"><div class="h-full min-h-0 min-w-0"><div class="h-full min-h-0 min-w-0" style="width: 100%; transform: none;"><div class="border border-token-border-light border-radius-3xl corner-superellipse/1.1 rounded-3xl"><div class="h-full w-full border-radius-3xl bg-token-bg-elevated-secondary corner-superellipse/1.1 overflow-clip rounded-3xl lxnfua_clipPathFallback"><div class="pointer-events-none absolute end-1.5 top-1 z-2 md:end-2 md:top-1"><button class="flex gap-1 items-center select-none pointer-events-auto py-2 text-sm font-medium hover:bg-black/5 dark:hover:bg-white/10 size-9 rounded-full px-2" aria-label="Copy" data-state="closed"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-md"><use href="/cdn/assets/sprites-core-il7yfj1b.svg#ce3544" fill="currentColor"></use></svg></button></div><div class="pe-11 pt-3" style="transform: none;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼ5 ͼj"><div class="cm-scroller"><div class="cm-content q9tKkq_readonly"><span>d3abc123xyz.cloudfront.net</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
<p data-start="1340" data-end="1370">Open that link in the browser.</p>
<p data-start="1372" data-end="1403">Your website should open again.</p>
<hr data-start="1405" data-end="1408">
<h1 data-section-id="1muzgsu" data-start="1410" data-end="1451">Step 7: Take Screenshots for Submission</h1>
<p data-start="1453" data-end="1477">You need screenshots of:</p>
<p data-start="1479" data-end="1660">1️⃣ S3 bucket list<br data-start="1497" data-end="1500">
2️⃣ index.html uploaded<br data-start="1523" data-end="1526">
3️⃣ Static website hosting enabled<br data-start="1560" data-end="1563">
4️⃣ Website opened in browser (like the screenshot you sent)<br data-start="1623" data-end="1626">
5️⃣ CloudFront distribution page</p>
<hr data-start="1662" data-end="1665">
<h1 data-section-id="lluwym" data-start="1667" data-end="1694">Step 8: Create README.txt</h1>
<p data-start="1696" data-end="1717">Create a file called:</p>
<pre class="overflow-visible! px-0!" data-start="1719" data-end="1737"><div class="relative w-full mt-4 mb-1"><div class=""><div class="relative"><div class="h-full min-h-0 min-w-0"><div class="h-full min-h-0 min-w-0" style="width: 100%; transform: none;"><div class="border border-token-border-light border-radius-3xl corner-superellipse/1.1 rounded-3xl"><div class="h-full w-full border-radius-3xl bg-token-bg-elevated-secondary corner-superellipse/1.1 overflow-clip rounded-3xl lxnfua_clipPathFallback"><div class="pointer-events-none absolute end-1.5 top-1 z-2 md:end-2 md:top-1"><button class="flex gap-1 items-center select-none pointer-events-auto py-2 text-sm font-medium hover:bg-black/5 dark:hover:bg-white/10 size-9 rounded-full px-2" aria-label="Copy" data-state="closed"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-md"><use href="/cdn/assets/sprites-core-il7yfj1b.svg#ce3544" fill="currentColor"></use></svg></button></div><div class="pe-11 pt-3" style="transform: none;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼ5 ͼj"><div class="cm-scroller"><div class="cm-content q9tKkq_readonly"><span>README.txt</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
<p data-start="1739" data-end="1750">Write this:</p>
